#!/usr/bin/env bash
set -euo pipefail

default_icon="folder_code"
default_branch_regex='^(?:[^/]+/)?(?P<subproj>[^/]+)/(?P<task>.+)$'

locus_bus="org.rsynapse.Locus"
locus_path="/org/rsynapse/Locus"
locus_interface="org.rsynapse.Locus.Relations1"
niri_bus="org.rsynapse.Niri"
niri_path="/org/rsynapse/Niri"
niri_interface="org.rsynapse.Niri1"

workspace_project_relation="org.rsynapse.workspace.project"
project_metadata_relation="org.rsynapse.project.metadata"
niri_workspace_kind="org.rsynapse.niri.workspace.id"
project_path_kind="org.rsynapse.project.path"

usage() {
  cat >&2 <<'EOF'
usage: proj <command> [args]

commands:
  root [path]
  metadata [--json] [key] [path]
  update [path]
  set-current [path]
  set_current [path]
  publish [path]
  clear [workspace-id]
EOF
}

die() {
  printf 'proj: %s\n' "$*" >&2
  exit 1
}

need() {
  command -v "$1" >/dev/null 2>&1 || die "$1 is required"
}

absolute_dir() {
  local path="${1:-.}"
  [[ -d "$path" ]] || die "not a directory: $path"
  realpath "$path"
}

project_root_for_path() {
  local dir root
  dir="$(absolute_dir "${1:-.}")"
  root="$(git -C "$dir" rev-parse --show-toplevel 2>/dev/null)" || return 1
  realpath "$root"
}

project_name() {
  local root="$1"
  basename "$root"
}

project_icon() {
  local query icon
  local -a args
  args=()
  for query in "$@"; do
    [[ -n "$query" ]] || continue
    args+=(--string "$query")
  done
  if [[ "${#args[@]}" -gt 0 ]] && icon="$(pick-icon "${args[@]}" --top 1 --json 2>/dev/null | jq -r '.[0].icon // empty')" && [[ -n "$icon" ]]; then
    printf '%s\n' "$icon"
  else
    printf '%s\n' "$default_icon"
  fi
}

git_output() {
  local root="$1"
  shift
  git -C "$root" "$@" 2>/dev/null || true
}

split_branch() {
  local branch="$1"
  local jq_regex
  jq_regex="${default_branch_regex//(?P</(?<}"
  jq -cn --arg branch "$branch" --arg regex "$jq_regex" '
    ($branch | capture($regex)? // {}) |
    {subproj: (.subproj // null), task: (.task // null)}
  '
}

branch_field() {
  local fields="$1"
  local key="$2"
  jq -r --arg key "$key" '.[$key] // empty' <<<"$fields"
}

display_main_for_project() {
  local name="$1"
  local fields="$2"
  local subproj task
  subproj="$(branch_field "$fields" subproj)"
  task="$(branch_field "$fields" task)"
  if [[ -n "$subproj" && -n "$task" ]]; then
    printf '%s\n' "$subproj"
  else
    printf '%s\n' "$name"
  fi
}

display_secondary_for_project() {
  local branch="$1"
  local fields="$2"
  local subproj task
  subproj="$(branch_field "$fields" subproj)"
  task="$(branch_field "$fields" task)"
  if [[ -n "$subproj" && -n "$task" ]]; then
    printf '%s\n' "$task"
  else
    printf '%s\n' "$branch"
  fi
}

project_ref() {
  local root="$1"
  printf 'project:%s\n' "$root"
}

workspace_ref() {
  local workspace="$1"
  workspace="${workspace#niri-workspace:}"
  workspace="${workspace##*/}"
  workspace="${workspace#workspace_}"
  [[ -n "$workspace" ]] || return 1
  printf 'niri-workspace:%s\n' "$workspace"
}

selected_workspace_id() {
  local path
  path="$(niri_get_property FocusedWorkspace | jq -r '.data[0] // empty')"
  [[ -n "$path" ]] || return 1
  path="${path##*/}"
  path="${path#workspace_}"
  [[ -n "$path" ]] || return 1
  printf '%s\n' "$path"
}

build_snapshot() {
  local root="$1"
  local name branch worktree worktree_name fields display_main display_secondary icon
  name="$(project_name "$root")"
  branch="$(git_output "$root" branch --show-current)"
  worktree="$(git_output "$root" rev-parse --show-toplevel)"
  worktree_name=""
  [[ -n "$worktree" ]] && worktree_name="$(basename "$worktree")"
  fields="$(split_branch "$branch")"
  display_main="$(display_main_for_project "$name" "$fields")"
  display_secondary="$(display_secondary_for_project "$branch" "$fields")"
  icon="$(project_icon "$display_main" "$display_secondary")"

  jq -cn \
    --arg subject "$(project_ref "$root")" \
    --arg path "$root" \
    --arg name "$name" \
    --arg icon "$icon" \
    --arg display_main "$display_main" \
    --arg display_secondary "$display_secondary" \
    --arg branch "$branch" \
    --arg worktree "$worktree_name" \
    --arg worktree_path "$worktree" \
    --argjson fields "$fields" '
      {
        subject: $subject,
        path: $path,
        name: $name,
        icon: $icon,
        "display-icon": $icon,
        "display-main": $display_main,
        "display-secondary": (if $display_secondary == "" then null else $display_secondary end),
        branch: (if $branch == "" then null else $branch end),
        worktree: (if $worktree == "" then null else $worktree end),
        "worktree-path": (if $worktree_path == "" then null else $worktree_path end),
        subproj: $fields.subproj,
        task: $fields.task,
        metadata: {}
      }
    '
}

snapshot_metadata_args() {
  local snapshot="$1"
  jq -r '
    to_entries[]
    | select(.key != "subject")
    | select(.value != null)
    | [
        .key,
        (if (.value | type) == "string" then .value else (.value | tojson) end)
      ]
    | @tsv
  ' <<<"$snapshot"
}

metadata_bus_args() {
  local snapshot="$1"
  local -n out_count="$2"
  local -n out_args="$3"
  out_count=0
  out_args=()
  while IFS=$'\t' read -r key value; do
    [[ -n "${key:-}" ]] || continue
    out_args+=("$key" "$value")
    out_count=$((out_count + 1))
  done < <(snapshot_metadata_args "$snapshot")
}

endpoint_bus_args_from_ref() {
  local ref="$1"
  local -n out_args="$2"
  local kind id
  case "$ref" in
    project:*)
      kind="$project_path_kind"
      id="${ref#project:}"
      ;;
    niri-workspace:*)
      kind="$niri_workspace_kind"
      id="${ref#niri-workspace:}"
      ;;
    *)
      die "unsupported locus endpoint ref: $ref"
      ;;
  esac
  out_args=(3 type stable-key kind "$kind" id "$id")
}

endpoint_json_to_ref_filter='
  def dict:
    if type == "array" then
      if (.[0]? | type) == "array" then
        map({key: .[0], value: .[1]}) | from_entries
      else
        from_entries
      end
    else
      .
    end;
  dict as $endpoint
  | if $endpoint.type == "stable-key" and $endpoint.kind == "'"$project_path_kind"'" then
      "project:\($endpoint.id)"
    elif $endpoint.type == "stable-key" and $endpoint.kind == "'"$niri_workspace_kind"'" then
      "niri-workspace:\($endpoint.id)"
    else
      empty
    end
'

# Locus transport boundary. Keep all busctl-specific details here so this can
# be replaced by a small CLI later without changing command behavior.
locus_call() {
  busctl --user call "$locus_bus" "$locus_path" "$locus_interface" "$@"
}

locus_call_json() {
  busctl --user --json=short call "$locus_bus" "$locus_path" "$locus_interface" "$@"
}

locus_set_one() {
  local subject="$1"
  local relation="$2"
  local target="$3"
  local snapshot="$4"
  local count
  local args
  local subject_args
  local target_args
  endpoint_bus_args_from_ref "$subject" subject_args
  endpoint_bus_args_from_ref "$target" target_args
  metadata_bus_args "$snapshot" count args
  locus_call SetOne 'a{ss}sa{ss}a{ss}' \
    "${subject_args[@]}" \
    "$relation" \
    "${target_args[@]}" \
    "$count" "${args[@]}" >/dev/null
}

locus_set() {
  local subject="$1"
  local relation="$2"
  local target="$3"
  local snapshot="$4"
  local count
  local args
  local subject_args
  local target_args
  endpoint_bus_args_from_ref "$subject" subject_args
  endpoint_bus_args_from_ref "$target" target_args
  metadata_bus_args "$snapshot" count args
  locus_call Set 'a{ss}sa{ss}a{ss}' \
    "${subject_args[@]}" \
    "$relation" \
    "${target_args[@]}" \
    "$count" "${args[@]}" >/dev/null
}

locus_clear() {
  local subject="$1"
  local relation="$2"
  local subject_args
  endpoint_bus_args_from_ref "$subject" subject_args
  locus_call Clear 'a{ss}s' "${subject_args[@]}" "$relation" >/dev/null
}

locus_unset() {
  local subject="$1"
  local relation="$2"
  local target="$3"
  local subject_args
  local target_args
  endpoint_bus_args_from_ref "$subject" subject_args
  endpoint_bus_args_from_ref "$target" target_args
  locus_call Unset 'a{ss}sa{ss}' "${subject_args[@]}" "$relation" "${target_args[@]}" >/dev/null
}

locus_subjects() {
  local relation="$1"
  local target="$2"
  local target_args
  endpoint_bus_args_from_ref "$target" target_args
  locus_call_json Subjects 'sa{ss}' "$relation" "${target_args[@]}" \
    | jq -r ".data[0][]? | $endpoint_json_to_ref_filter"
}

locus_targets() {
  local subject="$1"
  local relation="$2"
  local subject_args
  endpoint_bus_args_from_ref "$subject" subject_args
  locus_call_json Targets 'a{ss}s' "${subject_args[@]}" "$relation" \
    | jq -r ".data[0][]? | $endpoint_json_to_ref_filter"
}

# Niri transport boundary.
niri_get_property() {
  local property="$1"
  busctl --user --json=short get-property "$niri_bus" "$niri_path" "$niri_interface" "$property"
}

cmd_root() {
  project_root_for_path "${1:-.}" || die "project root not found"
}

cmd_metadata() {
  local json=false
  if [[ "${1:-}" == "--json" ]]; then
    json=true
    shift
  fi
  local key="${1:-}"
  local path="${2:-.}"
  if [[ "$json" == true ]]; then
    path="${1:-.}"
  elif [[ -z "$key" ]]; then
    die "metadata key is required"
  fi
  local root
  root="$(project_root_for_path "$path")" || die "project root not found"
  if [[ "$json" == true ]]; then
    build_snapshot "$root" | jq '.'
  else
    build_snapshot "$root" | jq -r --arg key "$key" '.[$key] // empty'
  fi
}

cmd_update() {
  local root snapshot target subject
  root="$(project_root_for_path "${1:-.}")" || return 0
  snapshot="$(build_snapshot "$root")"
  target="$(project_ref "$root")"

  locus_set "$target" "$project_metadata_relation" "$target" "$snapshot"

  while IFS= read -r subject; do
    [[ -n "$subject" ]] || continue
    locus_set_one "$subject" "$workspace_project_relation" "$target" "$snapshot"
  done < <(locus_subjects "$workspace_project_relation" "$target")
}

cmd_set_current() {
  local root snapshot workspace subject target
  root="$(project_root_for_path "${1:-.}")" || return 0
  snapshot="$(build_snapshot "$root")"
  workspace="$(selected_workspace_id)" || return 0
  subject="$(workspace_ref "$workspace")"
  target="$(project_ref "$root")"

  locus_set "$target" "$project_metadata_relation" "$target" "$snapshot"
  locus_set_one "$subject" "$workspace_project_relation" "$target" "$snapshot"
}

cmd_clear() {
  local workspace="${1:-}"
  if [[ -z "$workspace" ]]; then
    workspace="$(selected_workspace_id)" || return 0
  fi
  locus_clear "$(workspace_ref "$workspace")" "$workspace_project_relation"
}

main() {
  need jq
  need git
  need realpath
  need busctl
  local command="${1:-}"
  [[ -n "$command" ]] || { usage; exit 2; }
  shift || true
  case "$command" in
    root) cmd_root "$@" ;;
    metadata) cmd_metadata "$@" ;;
    update) cmd_update "$@" ;;
    set-current | set_current | publish) cmd_set_current "$@" ;;
    clear) cmd_clear "$@" ;;
    -h | --help | help) usage ;;
    *) usage; exit 2 ;;
  esac
}

main "$@"
